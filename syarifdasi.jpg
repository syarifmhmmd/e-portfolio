                            <p>Banjarmasin, Kalimantan Selatan</p>
                            <p class="small">Available for Remote Work</p>
                        </div>
                    </div>

                    <div class="card p-4 mt-4">
                        <h4 class="text-center mb-4">Menerima Project Pengembangan Sistem</h4>
                        <div class="row text-center">
                            <div class="col-md-4 mb-3">
                                <div class="p-3 border rounded h-100">
                                    <i class="fas fa-laptop-code fa-2x text-primary mb-3"></i>
                                    <h6>Web Development</h6>
                                    <p class="small mb-0">Sistem informasi custom</p>
                                </div>
                            </div>
