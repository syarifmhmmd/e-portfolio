    <!-- Hero Section -->
    <section id="home" class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="hero-title" style="font-size: 50px;">Syarif Hidayatullah, <span
                            class="highlight">S.Pd</span></h1>
                    <p style="color: gold;">Freelancer Web Developer | IT Consultant | UI/UX & Graphic
                        Design</p>
                    <p class="hero-subtitle">Lulusan Pendidikan Ilmu Komputer FKIP ULM</p>
                    <p class="lead mb-4">Specialist dalam pengembangan sistem informasi untuk pendidikan, kesehatan, dan
                        pemerintahan dengan teknologi web modern.</p>
                    <a href="#projects" class="btn btn-light btn-lg me-2">Lihat Proyek</a>
                    <a href="#contact" class="btn btn-outline-light btn-lg">Hubungi Saya</a>
                </div>
                <div class="col-lg-6 text-center">
