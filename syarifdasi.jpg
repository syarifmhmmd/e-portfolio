    <!-- Projects Section -->
    <section id="projects" class="py-5">
        <div class="container">
            <h2 class="section-title">Proyek yang Telah Dibuat</h2>

            <!-- Proyek Pendidikan - SIPAn -->
            <h3 class="mt-5 mb-4 text-primary"><i class="fas fa-graduation-cap me-2"></i>Sistem Pendidikan</h3>
            <div class="row mb-5">
                <div class="col-12 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title text-primary mb-0">SIPAn (Sistem Informasi Anestesiologi FKIK ULM)
                                </h5>
                                <span class="project-status status-completed">LIVE</span>
                            </div>
                            <p class="card-text mt-2">Platform terintegrasi untuk departemen Anestesiologi FKIK ULM yang
                                terdiri dari beberapa modul aplikasi:</p>

                            <div class="row mt-3">
                                <div class="col-md-6">
                                    <div class="p-3 border rounded mb-3">
                                        <h6><i class="fas fa-book me-2 text-primary"></i><strong>SILOGAN</strong> -
                                            Sistem Informasi Logbook Anestesiologi</h6>
                                        <p class="mb-0 small">Sistem pencatatan dan pelaporan kegiatan pendidikan
                                            residen anestesiologi</p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 border rounded mb-3">
                                        <h6><i class="fas fa-users me-2 text-success"></i><strong>SIPEDIK</strong> -
                                            Sistem Informasi Peserta Didik</h6>
                                        <p class="mb-0 small">Manajemen data peserta didik anestesiologi (mahasiswa,
                                            residen, peserta pelatihan)</p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 border rounded mb-3">
                                        <h6><i
                                                class="fas fa-cash-register me-2 text-warning"></i><strong>SILAKAS</strong>
                                            - Sistem Laporan Kas Anestesiologi</h6>
                                        <p class="mb-0 small">Pengelolaan dan pelaporan keuangan departemen
                                            anestesiologi</p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 border rounded mb-3">
                                        <h6><i class="fas fa-clipboard-check me-2 text-info"></i><strong>Absensi
                                                Digital</strong></h6>
                                        <p class="mb-0 small">Sistem presensi elektronik untuk dosen, mahasiswa, dan
                                            staf</p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 border rounded mb-3">
                                        <h6><i class="fas fa-book-reader me-2 text-danger"></i><strong>E-Library
                                                Anestesiologi</strong></h6>
